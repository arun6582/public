#!/usr/bin/env bash

set -e

# Initialize optional variables
repo_path=""
ssh_key=""

# Parse flags for repo_path and ssh_key
while [[ $# -gt 0 ]]; do
    case "$1" in
    -p | --path)
        repo_path="$2"
        shift 2
        ;;
    -k | --key)
        ssh_key="$2"
        shift 2
        ;;
    *)
        # The first positional argument is assumed to be repo_url
        repo_url="$1"
        shift
        ;;
    esac
done

# Check that repo_url is provided
if [[ -z "$repo_url" ]]; then
    echo "Usage: $0 <repo_url> [-p <repo_path>] [-k <ssh_key>]"
    exit 1
fi

# If repo_path is not specified, derive it from the repo name in the URL
if [[ -z "$repo_path" ]]; then
    repo_name=$(basename -s .git "$repo_url")
    repo_path="./$repo_name"
fi

# Check if the repo_path exists and contains a .git directory
if [[ ! -d "$repo_path/.git" ]]; then
    rm -rf "$repo_path"

    # Clone using an SSH key if provided
    if [[ -n "$ssh_key" ]]; then
        GIT_SSH_COMMAND="ssh -i $ssh_key" git clone "$repo_url" "$repo_path"
        cd "$repo_path"
        git config core.sshCommand "ssh -i $ssh_key"
        cd -
    else
        git clone "$repo_url" "$repo_path"
    fi
fi
